rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profilePath() { return /databases/$(database)/documents/usuarios/$(request.auth.uid); }
    function hasProfile() { return signedIn() && exists(profilePath()); }
    function profile() { return get(profilePath()).data; }
    function active() { return hasProfile() && profile().ativo == true; }
    function admin() { return active() && profile().perfil == 'admin'; }
    function guard() { return active() && profile().perfil == 'guarda'; }
    function validPerson(person) { return person is map && person.keys().hasOnly(['nome', 'matricula']) && person.nome == profile().nome && person.matricula == profile().matricula; }
    function validUser(data, uid) { return data.keys().hasOnly(['uid', 'nome', 'matricula', 'perfil', 'ativo', 'criadoEm', 'atualizadoEm']) && data.uid == uid && data.nome is string && data.nome.size() >= 2 && data.nome.size() <= 120 && data.matricula is string && data.matricula.size() >= 1 && data.matricula.size() <= 40 && data.perfil in ['admin', 'guarda'] && data.ativo is bool; }
    function validKey(data) { return data.keys().hasOnly(['codigo', 'nome', 'descricao', 'status', 'responsavelAtual', 'ultimaMovimentacaoEm', 'ultimaMovimentacaoId', 'arquivada']) && data.codigo is string && data.codigo.size() >= 2 && data.codigo.size() <= 40 && data.status in ['disponivel', 'em_uso'] && data.arquivada is bool; }
    function validMovement(data, movementId) { return guard() && data.keys().hasOnly(['id', 'chaveCodigo', 'tipo', 'responsavel', 'timestampLocal', 'deviceId', 'syncStatus', 'autorUid', 'chaveId']) && data.id == movementId && data.chaveCodigo is string && data.tipo in ['retirada', 'devolucao'] && validPerson(data.responsavel) && data.timestampLocal is timestamp && data.timestampLocal <= request.time + duration.value(5, 'm') && data.deviceId is string && data.deviceId.size() >= 1 && data.deviceId.size() <= 200 && data.syncStatus == 'sincronizado' && data.autorUid == request.auth.uid && data.chaveId is string; }

    match /usuarios/{uid} {
      allow get: if admin() || (signedIn() && request.auth.uid == uid);
      allow list: if admin();
      allow create: if admin() && validUser(request.resource.data, uid) && request.resource.data.perfil == 'guarda';
      allow update: if admin() && validUser(request.resource.data, uid) && request.resource.data.uid == resource.data.uid && request.resource.data.matricula == resource.data.matricula && request.resource.data.perfil == resource.data.perfil;
      allow delete: if admin();
    }
    match /acessos/{matricula} {
      allow read: if admin();
      allow create, update: if admin() && request.resource.data.keys().hasOnly(['uid', 'authEmail', 'ativo', 'criadoEm', 'atualizadoEm']) && request.resource.data.uid is string && request.resource.data.authEmail is string && request.resource.data.ativo is bool;
      allow delete: if admin();
    }
    match /chaves/{keyId} {
      allow read: if active();
      allow create: if admin() && validKey(request.resource.data) && request.resource.data.status == 'disponivel' && request.resource.data.responsavelAtual == null && request.resource.data.ultimaMovimentacaoEm == null && request.resource.data.arquivada == false;
      allow delete: if false;
      allow update: if (admin() && validKey(request.resource.data)) || (guard() && (!resource.data.keys().hasAny(['arquivada']) || resource.data.arquivada == false) && (!request.resource.data.keys().hasAny(['arquivada']) || request.resource.data.arquivada == false) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'responsavelAtual', 'ultimaMovimentacaoEm', 'ultimaMovimentacaoId']) && request.resource.data.codigo == resource.data.codigo && request.resource.data.ultimaMovimentacaoEm is timestamp && request.resource.data.ultimaMovimentacaoId is string && ((resource.data.status == 'disponivel' && request.resource.data.status == 'em_uso' && validPerson(request.resource.data.responsavelAtual)) || (resource.data.status == 'em_uso' && request.resource.data.status == 'disponivel' && request.resource.data.responsavelAtual == null)) && getAfter(/databases/$(database)/documents/movimentacoes/$(request.resource.data.ultimaMovimentacaoId)).data.autorUid == request.auth.uid);
    }
    match /movimentacoes/{movementId} {
      allow read: if active();
      allow create: if validMovement(request.resource.data, movementId)
        && getAfter(/databases/$(database)/documents/chaves/$(request.resource.data.chaveId)).data.ultimaMovimentacaoId == movementId
        && getAfter(/databases/$(database)/documents/chaves/$(request.resource.data.chaveId)).data.codigo == request.resource.data.chaveCodigo
        && getAfter(/databases/$(database)/documents/chaves/$(request.resource.data.chaveId)).data.ultimaMovimentacaoEm == request.resource.data.timestampLocal
        && ((request.resource.data.tipo == 'retirada'
          && getAfter(/databases/$(database)/documents/chaves/$(request.resource.data.chaveId)).data.status == 'em_uso'
          && getAfter(/databases/$(database)/documents/chaves/$(request.resource.data.chaveId)).data.responsavelAtual == request.resource.data.responsavel)
          || (request.resource.data.tipo == 'devolucao'
          && getAfter(/databases/$(database)/documents/chaves/$(request.resource.data.chaveId)).data.status == 'disponivel'
          && getAfter(/databases/$(database)/documents/chaves/$(request.resource.data.chaveId)).data.responsavelAtual == null));
      allow update, delete: if false;
    }
    match /auditoria/{eventId} {
      allow read: if admin();
      allow create: if admin() && request.resource.data.keys().hasOnly(['acao', 'alvo', 'detalhes', 'autorUid', 'criadoEm']) && request.resource.data.acao is string && request.resource.data.alvo is string && request.resource.data.detalhes is string && request.resource.data.autorUid == request.auth.uid && request.resource.data.criadoEm == request.time;
      allow update, delete: if false;
    }
    match /{document=**} { allow read, write: if false; }
  }
}
