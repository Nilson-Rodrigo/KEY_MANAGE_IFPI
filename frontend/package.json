{
  "name": "coretech-chaves-frontend",
  "version": "1.0.0",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --no-cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run lint && npm run typecheck && npm run test",
    "build": "expo export -p web",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "@expo-google-fonts/material-symbols": "^0.4.41",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "expo": "~57.0.7",
    "expo-background-task": "~57.0.5",
    "expo-build-properties": "~57.0.6",
    "expo-constants": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-network": "~57.0.1",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "^57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-task-manager": "~57.0.5",
    "firebase": "^12.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.4",
    "eslint": "^9.9.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.9"
