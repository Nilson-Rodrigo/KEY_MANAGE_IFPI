{
  "expo": {
    "name": "coretech-chaves",
    "slug": "coretech-chaves",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coretech.chaves"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "package": "com.coretech.chaves",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2563eb"
        }
      ]
    ],
    "scheme": "coretech-chaves",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f856830-b495-468b-b259-a920f7864e80"
      }
    }
  }
}
