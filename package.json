{
  "name": "coretech-chaves",
  "version": "1.0.0",
  "type": "module",
  "description": "Sistema de Gerenciamento de Acesso a Chaves — IFPI Campus Piripiri (CoreTech)",
  "scripts": {
    "build": "tsc",
    "lint": "eslint scripts --ext .ts",
    "lint:fix": "eslint scripts --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck",
    "verify:frontend": "npm --prefix frontend run verify && npm --prefix frontend run build",
    "verify:all": "npm run verify && npm run verify:frontend",
    "rules:check": "firebase emulators:exec --only firestore \"tsx scripts/rules-smoke.ts\"",
    "emulators:start": "firebase emulators:start --only auth,firestore,hosting",
    "seed": "tsx scripts/seed-firestore.ts",
    "seed:prod": "tsx scripts/seed-prod.ts",
    "provision:admin": "tsx scripts/provision-admin.ts",
    "deploy": "npm run deploy:firebase",
    "deploy:firebase": "npm run verify:all && firebase deploy --only hosting,firestore:rules"
  },
  "keywords": [
    "ifpi",
    "coretech",
    "chaves",
    "firestore"
  ],
  "author": "CoreTech",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "firebase-admin": "^12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.9.0",
    "firebase-tools": "^13.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
